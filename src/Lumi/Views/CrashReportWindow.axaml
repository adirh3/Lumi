<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:Lumi.Localization"
        x:Class="Lumi.Views.CrashReportWindow"
        x:Name="CrashReporterRoot"
        Title="{loc:Str Crash_WindowTitle}"
        Width="760"
        Height="640"
        MinWidth="620"
        MinHeight="500"
        WindowStartupLocation="CenterScreen"
        CanResize="True"
        ShowInTaskbar="True"
        UseLayoutRounding="True"
        Background="{DynamicResource Brush.SurfaceCard}">

  <Border Background="{DynamicResource Brush.SurfaceCard}"
          Padding="28">
    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto"
          RowSpacing="18">
      <Grid Grid.Row="0"
            ColumnDefinitions="52,*"
            ColumnSpacing="16">
        <Border Width="48"
                Height="48"
                CornerRadius="24"
                Background="{DynamicResource Brush.DangerSubtle}">
          <TextBlock Text="!"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     FontSize="28"
                     FontWeight="Bold"
                     Foreground="{DynamicResource Brush.DangerDefault}" />
        </Border>

        <StackPanel Grid.Column="1"
                    Spacing="5"
                    VerticalAlignment="Center">
          <TextBlock Text="{loc:Str Crash_Title}"
                     FontSize="{DynamicResource Font.SizeTitle}"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource Brush.TextPrimary}" />
          <TextBlock Text="{loc:Str Crash_Description}"
                     TextWrapping="Wrap"
                     FontSize="{DynamicResource Font.SizeBody}"
                     Foreground="{DynamicResource Brush.TextSecondary}" />
        </StackPanel>
      </Grid>

      <Border Grid.Row="1"
              Padding="14,12"
              CornerRadius="{DynamicResource Radius.Base}"
              Background="{DynamicResource Brush.AccentSubtle}"
              BorderBrush="{DynamicResource Brush.BorderSubtle}"
              BorderThickness="1">
        <TextBlock Text="{loc:Str Crash_EmailHint}"
                   TextWrapping="Wrap"
                   FontSize="{DynamicResource Font.SizeCaption}"
                   Foreground="{DynamicResource Brush.TextSecondary}" />
      </Border>

      <Expander Grid.Row="2"
                Header="{loc:Str Crash_Details}"
                IsExpanded="True"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
        <Border Margin="0,10,0,0"
                Background="{DynamicResource Brush.SurfaceSubtle}"
                BorderBrush="{DynamicResource Brush.BorderSubtle}"
                BorderThickness="1"
                CornerRadius="{DynamicResource Radius.Base}"
                ClipToBounds="True">
          <TextBox x:Name="CrashReportDetails"
                   IsReadOnly="True"
                   AcceptsReturn="True"
                   TextWrapping="NoWrap"
                   FontFamily="Consolas, Menlo, monospace"
                   FontSize="12"
                   Background="Transparent"
                   BorderThickness="0"
                   Padding="12"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch"
                   ScrollViewer.HorizontalScrollBarVisibility="Auto"
                   ScrollViewer.VerticalScrollBarVisibility="Auto" />
        </Border>
      </Expander>

      <StackPanel Grid.Row="3"
                  Spacing="4">
        <TextBlock x:Name="CrashReportProgress"
                   IsVisible="False"
                   TextWrapping="Wrap"
                   FontSize="{DynamicResource Font.SizeCaption}"
                   Foreground="{DynamicResource Brush.TextSecondary}" />
        <TextBlock x:Name="CrashReportStatus"
                   IsVisible="False"
                   TextWrapping="Wrap"
                   FontSize="{DynamicResource Font.SizeCaption}"
                   Foreground="{DynamicResource Brush.DangerDefault}" />
      </StackPanel>

      <StackPanel Grid.Row="4"
                  Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  Spacing="10">
        <Button x:Name="RestartLumiButton"
                Classes="subtle"
                Content="{loc:Str Crash_Restart}"
                Padding="18,9"
                MinHeight="0"
                Click="OnRestartLumiClick" />
        <Button x:Name="SendFeedbackButton"
                Classes="accent"
                Content="{loc:Str Crash_SendAndRestart}"
                Padding="18,9"
                MinHeight="0"
                IsDefault="True"
                Click="OnSendFeedbackClick" />
      </StackPanel>
    </Grid>
  </Border>
</Window>
