<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:sa="using:StrataTheme.Animation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Lumi.ViewModels"
             xmlns:m="using:Lumi.Models"
             xmlns:conv="using:Lumi.Converters"
             xmlns:sc="using:StrataTheme.Controls"
             xmlns:ctrl="using:Lumi.Views.Controls"
             xmlns:loc="using:Lumi.Localization"
             x:Class="Lumi.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             x:CompileBindings="True">

  <UserControl.Resources>
    <conv:ModelDisplayConverter x:Key="ModelDisplayConverter" />
    <conv:ByokEndpointByIdConverter x:Key="ByokEndpointByIdConverter"
                                    EndpointSource="{Binding ByokEndpoints}" />
    <conv:StringToNullableIntConverter x:Key="StringToNullableIntConverter" />
  </UserControl.Resources>

  <UserControl.Styles>
    <Style Selector="Border.motion-surface, DockPanel.motion-surface, StackPanel.motion-surface">
      <Setter Property="Opacity" Value="0" />
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Border.motion-surface[IsVisible=true], DockPanel.motion-surface[IsVisible=true], StackPanel.motion-surface[IsVisible=true]">
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Button.motion-action">
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.12" />
          <sa:PremultipliedBrushTransition Property="Background" Duration="0:0:0.12" />
          <BrushTransition Property="BorderBrush" Duration="0:0:0.12" />
        </Transitions>
      </Setter>
    </Style>
  </UserControl.Styles>

  <Panel>

    <!-- ═══ Restart banner (shown when a restart-required setting changes) ═══ -->
    <Border x:Name="RestartBanner"
            Classes="motion-surface"
            IsVisible="{Binding NeedsRestart}"
            Background="{DynamicResource Brush.WarningSubtle}"
            CornerRadius="8" Padding="16,10" Margin="36,24,36,0"
            MaxWidth="560" HorizontalAlignment="Left"
            VerticalAlignment="Top" ZIndex="10">
      <DockPanel>
        <Button DockPanel.Dock="Right" Classes="accent motion-action" Content="{loc:Str Settings_Restart}"
                Padding="14,6" MinHeight="0" Margin="12,0,0,0"
                Command="{Binding RestartAppCommand}" />
        <TextBlock Text="{loc:Str Settings_RestartBanner}"
                   VerticalAlignment="Center" FontSize="{DynamicResource Font.SizeCaption}"
                   Foreground="{DynamicResource Brush.TextPrimary}" />
      </DockPanel>
    </Border>

    <ScrollViewer x:Name="MainScrollViewer" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel x:Name="AllPagesStack" Spacing="0">

    <!-- Search results header (shown during search) -->
    <DockPanel x:Name="SearchResultsHeader" Classes="motion-surface" IsVisible="False"
              Margin="36,24,36,4" MaxWidth="560" HorizontalAlignment="Left">
      <Button x:Name="ClearSearchButton" DockPanel.Dock="Right" Classes="subtle motion-action"
              Content="{loc:Str Common_Clear}" Padding="8,4" MinHeight="0" MinWidth="0"
              FontSize="{DynamicResource Font.SizeCaption}"
              Foreground="{DynamicResource Brush.AccentDefault}"
              VerticalAlignment="Center" />
      <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
        <PathIcon Width="14" Height="14" Foreground="{DynamicResource Brush.TextTertiary}">
          <PathIcon.Data>
            <StreamGeometry>M10 3a7 7 0 1 0 4.2 12.6l4.1 4.1a1 1 0 0 0 1.4-1.4l-4.1-4.1A7 7 0 0 0 10 3zm-5 7a5 5 0 1 1 10 0 5 5 0 0 1-10 0z</StreamGeometry>
          </PathIcon.Data>
        </PathIcon>
        <StackPanel Orientation="Horizontal" Spacing="0">
          <TextBlock x:Name="SearchCountText" FontSize="13" FontWeight="SemiBold"
                     Foreground="{DynamicResource Brush.AccentDefault}" />
          <TextBlock x:Name="SearchQueryText" FontSize="13"
                     Foreground="{DynamicResource Brush.TextSecondary}" />
        </StackPanel>
      </StackPanel>
    </DockPanel>

    <!-- ═══ Page 0: Profile ═══ -->
      <StackPanel x:Name="PageProfile" Classes="motion-surface" Spacing="20" Margin="36,24,36,36" MaxWidth="560">
        <StackPanel Spacing="4">
          <TextBlock Text="{loc:Str Settings_Profile}" FontSize="{DynamicResource Font.SizeTitle}" FontWeight="SemiBold" />
          <TextBlock Text="{loc:Str Settings_ProfileDesc}" FontSize="{DynamicResource Font.SizeCaption}"
                     Foreground="{DynamicResource Brush.TextTertiary}" />
        </StackPanel>

        <sc:StrataSettingGroup Header="{loc:Str SettingsGroup_Profile}">
          <sc:StrataSetting Header="{loc:Str Setting_YourName}" Description="{loc:Str SettingDesc_YourName}">
            <TextBox Text="{Binding UserName}" PlaceholderText="{loc:Str Watermark_EnterName}" Width="220" />
          </sc:StrataSetting>
          <sc:StrataSetting Header="{loc:Str Setting_Sex}" Description="{loc:Str SettingDesc_Sex}">
            <ComboBox x:Name="SettingsSexCombo" Width="220"
                      SelectedIndex="{Binding UserSexIndex}" />
          </sc:StrataSetting>
        </sc:StrataSettingGroup>

        <sc:StrataSettingGroup Header="{loc:Str SettingsGroup_Language}">
          <sc:StrataSetting Header="{loc:Str Setting_Language}" Description="{loc:Str SettingDesc_Language}">
            <ComboBox ItemsSource="{Binding LanguageOptions}"
                      SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                      Width="200" />
          </sc:StrataSetting>
        </sc:StrataSettingGroup>
      </StackPanel>

    <!-- ═══ Page 1: General ═══ -->
      <StackPanel x:Name="PageGeneral" Classes="motion-surface" IsVisible="False" Spacing="20" Margin="36,24,36,36" MaxWidth="560">
        <StackPanel Spacing="4">
          <TextBlock Text="{loc:Str Settings_General}" FontSize="{DynamicResource Font.SizeTitle}" FontWeight="SemiBold" />
          <TextBlock Text="{loc:Str Settings_GeneralDesc}" FontSize="{DynamicResource Font.SizeCaption}"
                     Foreground="{DynamicResource Brush.TextTertiary}" />
        </StackPanel>

        <sc:StrataSettingGroup Header="{loc:Str SettingsGroup_Startup}">
          <sc:StrataSetting Header="{loc:Str Setting_LaunchAtStartup}" Description="{loc:Str SettingDesc_LaunchAtStartup}"
                            IsModified="{Binding IsLaunchAtStartupModified}">
            <ToggleSwitch IsChecked="{Binding LaunchAtStartup}" />
          </sc:StrataSetting>
          <sc:StrataSetting Header="{loc:Str Setting_StartMinimized}" Description="{loc:Str SettingDesc_StartMinimized}"
                            IsModified="{Binding IsStartMinimizedModified}">
            <ToggleSwitch IsChecked="{Binding StartMinimized}" />
          </sc:StrataSetting>
          <sc:StrataSetting Header="{loc:Str Setting_MinimizeToTray}" Description="{loc:Str SettingDesc_MinimizeToTray}"
                            IsModified="{Binding IsMinimizeToTrayModified}">
            <ToggleSwitch IsChecked="{Binding MinimizeToTray}" />
          </sc:StrataSetting>
        </sc:StrataSettingGroup>

        <sc:StrataSettingGroup Header="{loc:Str SettingsGroup_Notifications}">
          <sc:StrataSetting Header="{loc:Str Setting_EnableNotifications}" Description="{loc:Str SettingDesc_EnableNotifications}"
                            IsModified="{Binding IsNotificationsEnabledModified}">
            <ToggleSwitch IsChecked="{Binding NotificationsEnabled}" />
          </sc:StrataSetting>
        </sc:StrataSettingGroup>

        <sc:StrataSettingGroup Header="{loc:Str SettingsGroup_Keyboard}">
          <sc:StrataSetting Header="{loc:Str Setting_GlobalHotkey}" Description="{loc:Str SettingDesc_GlobalHotkey}"
                            IsModified="{Binding IsGlobalHotkeyModified}">
            <Button x:Name="HotkeyRecorderButton" Classes="subtle motion-action" Padding="14,6" MinHeight="0"
                    MinWidth="120" HorizontalContentAlignment="Center"
                    FontSize="{DynamicResource Font.SizeCaption}" />
          </sc:StrataSetting>
        </sc:StrataSettingGroup>
      </StackPanel>

    <!-- ═══ Page 2: Appearance ═══ -->
      <StackPanel x:Name="PageAppearance" Classes="motion-surface" IsVisible="False" Spacing="20" Margin="36,24,36,36" MaxWidth="560">
        <StackPanel Spacing="4">
          <TextBlock Text="{loc:Str Settings_Appearance}" FontSize="{DynamicResource Font.SizeTitle}" FontWeight="SemiBold" />
          <TextBlock Text="{loc:Str Settings_AppearanceDesc}" FontSize="{DynamicResource Font.SizeCaption}"
                     Foreground="{DynamicResource Brush.TextTertiary}" />
        </StackPanel>

        <sc:StrataSettingGroup Header="{loc:Str SettingsGroup_Theme}">
          <sc:StrataSetting Header="{loc:Str Setting_DarkMode}" Description="{loc:Str SettingDesc_DarkMode}"
                            IsModified="{Binding IsDarkThemeModified}">
            <ToggleSwitch IsChecked="{Binding IsDarkTheme}" />
          </sc:StrataSetting>
        </sc:StrataSettingGroup>

        <sc:StrataSettingGroup Header="{loc:Str SettingsGroup_Layout}">
          <sc:StrataSetting Header="{loc:Str Setting_CompactDensity}" Description="{loc:Str SettingDesc_CompactDensity}"
                            IsModified="{Binding IsCompactDensityModified}">
            <ToggleSwitch IsChecked="{Binding IsCompactDensity}" />
          </sc:StrataSetting>
          <sc:StrataSetting Header="{loc:Str Setting_FontSize}" Description="{loc:Str SettingDesc_FontSize}"
                            IsModified="{Binding IsFontSizeModified}">
            <StackPanel Orientation="Horizontal" Spacing="12">
              <Slider Minimum="11" Maximum="18" Value="{Binding FontSize}"
                      TickFrequency="1" IsSnapToTickEnabled="True" Width="140" />
              <TextBlock Text="{Binding FontSize, StringFormat='{}{0}px'}"
                         VerticalAlignment="Center" FontSize="{DynamicResource Font.SizeCaption}"
                         Foreground="{DynamicResource Brush.TextSecondary}" MinWidth="32" />
            </StackPanel>
          </sc:StrataSetting>
        </sc:StrataSettingGroup>

        <sc:StrataSettingGroup Header="{loc:Str SettingsGroup_Motion}">
          <sc:StrataSetting Header="{loc:Str Setting_ShowAnimations}" Description="{loc:Str SettingDesc_ShowAnimations}"
                            IsModified="{Binding IsShowAnimationsModified}">
            <ToggleSwitch IsChecked="{Binding ShowAnimations}" />
          </sc:StrataSetting>
        </sc:StrataSettingGroup>
      </StackPanel>

    <!-- ═══ Page 3: Chat ═══ -->
      <StackPanel x:Name="PageChat" Classes="motion-surface" IsVisible="False" Spacing="20" Margin="36,24,36,36" MaxWidth="560">
        <StackPanel Spacing="4">
          <TextBlock Text="{loc:Str Settings_Chat}" FontSize="{DynamicResource Font.SizeTitle}" FontWeight="SemiBold" />
          <TextBlock Text="{loc:Str Settings_ChatDesc}" FontSize="{DynamicResource Font.SizeCaption}"
                     Foreground="{DynamicResource Brush.TextTertiary}" />
        </StackPanel>

        <sc:StrataSettingGroup Header="{loc:Str SettingsGroup_Input}">
          <sc:StrataSetting Header="{loc:Str Setting_SendWithEnter}" Description="{loc:Str SettingDesc_SendWithEnter}"
                            IsModified="{Binding IsSendWithEnterModified}">
            <ToggleSwitch IsChecked="{Binding SendWithEnter}" />
          </sc:StrataSetting>
        </sc:StrataSettingGroup>

        <sc:StrataSettingGroup Header="{loc:Str SettingsGroup_Display}">
          <sc:StrataSetting Header="{loc:Str Setting_ShowTimestamps}" Description="{loc:Str SettingDesc_ShowTimestamps}"
                            IsModified="{Binding IsShowTimestampsModified}">
            <ToggleSwitch IsChecked="{Binding ShowTimestamps}" />
          </sc:StrataSetting>
          <sc:StrataSetting Header="{loc:Str Setting_ShowToolCalls}" Description="{loc:Str SettingDesc_ShowToolCalls}"
                            IsModified="{Binding IsShowToolCallsModified}">
            <ToggleSwitch IsChecked="{Binding ShowToolCalls}" />
          </sc:StrataSetting>
          <sc:StrataSetting Header="{loc:Str Setting_ShowReasoning}" Description="{loc:Str SettingDesc_ShowReasoning}"
                            IsModified="{Binding IsShowReasoningModified}">
            <ToggleSwitch IsChecked="{Binding ShowReasoning}" />
          </sc:StrataSetting>
          <sc:StrataSetting Header="{loc:Str Setting_ExpandReasoningWhileStreaming}" Description="{loc:Str SettingDesc_ExpandReasoningWhileStreaming}"
                            IsModified="{Binding IsExpandReasoningWhileStreamingModified}">
            <ToggleSwitch IsChecked="{Binding ExpandReasoningWhileStreaming}" />
          </sc:StrataSetting>
        </sc:StrataSettingGroup>

        <sc:StrataSettingGroup Header="{loc:Str SettingsGroup_Behavior}">
          <sc:StrataSetting Header="{loc:Str Setting_AutoGenerateTitles}" Description="{loc:Str SettingDesc_AutoGenerateTitles}"
                            IsModified="{Binding IsAutoGenerateTitlesModified}">
            <ToggleSwitch IsChecked="{Binding AutoGenerateTitles}" />
          </sc:StrataSetting>
        </sc:StrataSettingGroup>
      </StackPanel>

    <!-- ═══ Page 4: AI & Models ═══ -->
      <StackPanel x:Name="PageAI" Classes="motion-surface" IsVisible="False" Spacing="20" Margin="36,24,36,36" MaxWidth="560">
        <StackPanel Spacing="4">
          <TextBlock Text="{loc:Str Settings_AIModels}" FontSize="{DynamicResource Font.SizeTitle}" FontWeight="SemiBold" />
          <TextBlock Text="{loc:Str Settings_AIModelsDesc}" FontSize="{DynamicResource Font.SizeCaption}"
                     Foreground="{DynamicResource Brush.TextTertiary}" />
        </StackPanel>

        <sc:StrataSettingGroup Header="{loc:Str SettingsGroup_GitHubAccount}">
          <sc:StrataSetting Header="{loc:Str Setting_GitHubAccount}" Description="{loc:Str SettingDesc_GitHubAccount}">
            <StackPanel Spacing="8" VerticalAlignment="Center">
              <ctrl:GitHubLoginView x:Name="SettingsLoginView" />

              <TextBlock Text="{Binding GitHubAuthErrorText}"
                         IsVisible="{Binding GitHubAuthErrorText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                         FontSize="{DynamicResource Font.SizeCaption}"
                         Foreground="{DynamicResource Brush.DangerDefault}"
                         TextWrapping="Wrap"
                         MaxWidth="360" />
            </StackPanel>
          </sc:StrataSetting>
          <sc:StrataSetting Header="Usage Quota" Description="Your Copilot usage quota for the current billing period."
                            IsVisible="{Binding QuotaDisplayText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding QuotaDisplayText}" FontSize="{DynamicResource Font.SizeCaption}"
                       Foreground="{DynamicResource Brush.TextSecondary}"
                       VerticalAlignment="Center" />
          </sc:StrataSetting>
        </sc:StrataSettingGroup>

        <sc:StrataSettingGroup Header="{loc:Str SettingsGroup_Model}">
          <sc:StrataSetting Header="{loc:Str Setting_PreferredModel}" Description="{loc:Str SettingDesc_PreferredModel}"
                            IsModified="{Binding IsDefaultModelSelectionModified}">
            <sc:StrataModelPicker Width="300"
                                  Models="{Binding AvailableModels}"
                                  SelectedModel="{Binding PreferredModel, Mode=TwoWay}"
                                  QualityLevels="{Binding QualityLevels}"
                                  SelectedQuality="{Binding SelectedQuality, Mode=TwoWay}"
                                  ContextWindowTiers="{Binding ContextWindowTiers}"
                                  SelectedContextWindowTier="{Binding SelectedContextWindowTier, Mode=TwoWay}">
              <sc:StrataModelPicker.ModelItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Converter={StaticResource ModelDisplayConverter}}" />
                </DataTemplate>
              </sc:StrataModelPicker.ModelItemTemplate>
            </sc:StrataModelPicker>
          </sc:StrataSetting>
        </sc:StrataSettingGroup>

        <!-- ═══ BYOK ═══ -->
        <sc:StrataSettingGroup Header="{loc:Str SettingsGroup_Byok}">
          <StackPanel Spacing="16">
            <TextBlock Text="{loc:Str Settings_Byok_Description}"
                       FontSize="{DynamicResource Font.SizeCaption}"
                       Foreground="{DynamicResource Brush.TextTertiary}"
                       TextWrapping="Wrap" />

            <!-- ── Privacy guard: block all non-BYOK requests ── -->
            <Border Background="{DynamicResource Brush.SurfaceCard}"
                    CornerRadius="8"
                    Padding="12,10">
              <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="10">
                  <ToggleSwitch IsChecked="{Binding UseBYOKOnly}" />
                  <TextBlock Text="{loc:Str Settings_Byok_UseByokOnly}"
                             FontWeight="SemiBold"
                             VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Text="{loc:Str Settings_Byok_UseByokOnlyHint}"
                           FontSize="{DynamicResource Font.SizeCaption}"
                           Foreground="{DynamicResource Brush.TextTertiary}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <!-- ── Endpoints ── -->
            <StackPanel Spacing="8">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{loc:Str SettingsGroup_ByokEndpoints}" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button Padding="8,3" MinHeight="0"
                        Classes="subtle motion-action"
                        Command="{Binding AddByokEndpointCommand}">
                      <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="＋" /><TextBlock Text="{loc:Str Settings_Byok_AddEndpoint}" />
                      </StackPanel>
                    </Button>
              </StackPanel>

              <ListBox ItemsSource="{Binding ByokEndpoints}"
                       SelectedItem="{Binding SelectedByokEndpoint, Mode=TwoWay}"
                       MinHeight="60" MaxHeight="180"
                       Background="{DynamicResource Brush.Surface2}"
                       BorderBrush="{DynamicResource Brush.Border1}"
                       BorderThickness="1" CornerRadius="6">
                <ListBox.ItemTemplate>
                  <DataTemplate DataType="m:ByokEndpoint">
                    <StackPanel Spacing="2">
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding ProviderType}" FontSize="{DynamicResource Font.SizeCaption}"
                                   Foreground="{DynamicResource Brush.TextTertiary}" />
                      </StackPanel>
                      <TextBlock Text="{Binding BaseUrl}" FontSize="{DynamicResource Font.SizeCaption}"
                                 Foreground="{DynamicResource Brush.TextTertiary}" />
                    </StackPanel>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
              <TextBlock Text="{loc:Str Settings_Byok_EmptyEndpoints}"
                         IsVisible="{Binding !ByokEndpoints.Count}"
                         Foreground="{DynamicResource Brush.TextTertiary}"
                         FontSize="{DynamicResource Font.SizeCaption}"
                         TextWrapping="Wrap" />

              <!-- Endpoint editor -->
              <Border IsVisible="{Binding IsByokEndpointSelected}"
                      Padding="14" CornerRadius="8" Margin="0,4,0,0"
                      Background="{DynamicResource Brush.Surface2}"
                      BorderBrush="{DynamicResource Brush.Border1}"
                      BorderThickness="1">
                <StackPanel Spacing="10">
                  <DockPanel LastChildFill="False">
                    <Button DockPanel.Dock="Left" Padding="8,3" MinHeight="0"
                            Classes="subtle motion-action"
                            Command="{Binding CloseByokEndpointCommand}"
                            ToolTip.Tip="{loc:Str Settings_Byok_CloseEndpoint}">
                      <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="✕" /><TextBlock Text="{loc:Str Settings_Byok_CloseEndpoint}" />
                      </StackPanel>
                    </Button>
                    <StackPanel Orientation="Horizontal" Spacing="8" DockPanel.Dock="Right">
                      <Button Content="{loc:Str Settings_Byok_DuplicateEndpoint}" Padding="8,3" MinHeight="0"
                              Classes="subtle motion-action"
                              Command="{Binding DuplicateByokEndpointCommand}" />
                      <Button Content="{loc:Str Settings_Byok_DeleteEndpoint}" Padding="8,3" MinHeight="0"
                              Classes="danger subtle motion-action"
                              Command="{Binding DeleteByokEndpointCommand}" />
                    </StackPanel>
                  </DockPanel>

                  <StackPanel Spacing="4">
                    <TextBlock Text="{loc:Str Settings_Byok_EndpointName}" FontSize="{DynamicResource Font.SizeCaption}"
                               Foreground="{DynamicResource Brush.TextSecondary}" />
                    <TextBox Text="{Binding SelectedByokEndpoint.Name, Mode=TwoWay}"
                             PlaceholderText="{loc:Str Settings_Byok_EndpointNamePlaceholder}" />
                  </StackPanel>

                  <StackPanel Spacing="4">
                    <TextBlock Text="{loc:Str Settings_Byok_ProviderType}" FontSize="{DynamicResource Font.SizeCaption}"
                               Foreground="{DynamicResource Brush.TextSecondary}" />
                    <ComboBox ItemsSource="{Binding ByokProviderTypes}"
                              SelectedItem="{Binding SelectedByokEndpoint.ProviderType, Mode=TwoWay}"
                              HorizontalAlignment="Stretch" />
                  </StackPanel>

                  <StackPanel Spacing="4">
                    <TextBlock Text="{loc:Str Settings_Byok_BaseUrl}" FontSize="{DynamicResource Font.SizeCaption}"
                               Foreground="{DynamicResource Brush.TextSecondary}" />
                    <TextBox Text="{Binding SelectedByokEndpoint.BaseUrl, Mode=TwoWay}"
                             PlaceholderText="{loc:Str Settings_Byok_BaseUrlPlaceholder}" />
                  </StackPanel>

                  <StackPanel Spacing="4" IsVisible="{Binding IsSelectedByokWireApiVisible}">
                    <TextBlock Text="{loc:Str Settings_Byok_WireApi}" FontSize="{DynamicResource Font.SizeCaption}"
                               Foreground="{DynamicResource Brush.TextSecondary}" />
                    <ComboBox ItemsSource="{Binding ByokWireApiOptions}"
                              SelectedItem="{Binding SelectedByokEndpoint.WireApi, Mode=TwoWay}"
                              HorizontalAlignment="Stretch" />
                    <TextBlock Text="{loc:Str Settings_Byok_WireApiHint}"
                               FontSize="{DynamicResource Font.SizeCaption}"
                               Foreground="{DynamicResource Brush.TextTertiary}" />
                  </StackPanel>

                  <StackPanel Spacing="4" IsVisible="{Binding IsSelectedByokAzure}">
                    <TextBlock Text="{loc:Str Settings_Byok_AzureApiVersion}" FontSize="{DynamicResource Font.SizeCaption}"
                               Foreground="{DynamicResource Brush.TextSecondary}" />
                    <TextBox Text="{Binding SelectedByokEndpoint.AzureApiVersion, Mode=TwoWay}"
                             PlaceholderText="{loc:Str Settings_Byok_AzureApiVersionPlaceholder}" />
                  </StackPanel>

                  <StackPanel Spacing="4">
                    <TextBlock Text="{loc:Str Settings_Byok_ApiKeyMode}" FontSize="{DynamicResource Font.SizeCaption}"
                               Foreground="{DynamicResource Brush.TextSecondary}" />
                    <ComboBox Name="ByokApiKeyModePicker"
                              ItemsSource="{Binding ByokApiKeyModeOptions}"
                              SelectedItem="{Binding SelectedByokEndpointApiKeyModeOption, Mode=OneWay}"
                              SelectionChanged="OnByokApiKeyModeSelectionChanged"
                              HorizontalAlignment="Stretch" />
                  </StackPanel>

                  <StackPanel Spacing="4" IsVisible="{Binding UsesEnvVarApiKey}">
                    <TextBlock Text="{loc:Str Settings_Byok_ApiKeyEnvVar}" FontSize="{DynamicResource Font.SizeCaption}"
                               Foreground="{DynamicResource Brush.TextSecondary}" />
                    <TextBox Text="{Binding SelectedByokEndpoint.ApiKeyEnvVar, Mode=TwoWay}"
                             PlaceholderText="{loc:Str Settings_Byok_ApiKeyEnvVarPlaceholder}" />
                    <TextBlock Text="{loc:Str Settings_Byok_ApiKeyEnvVarHint}"
                               FontSize="{DynamicResource Font.SizeCaption}"
                               Foreground="{DynamicResource Brush.TextTertiary}" />
                  </StackPanel>

                  <StackPanel Spacing="4" IsVisible="{Binding UsesStoredApiKey}">
                    <TextBlock Text="{loc:Str Settings_Byok_ApiKey}" FontSize="{DynamicResource Font.SizeCaption}"
                               Foreground="{DynamicResource Brush.TextSecondary}" />
                    <TextBox Text="{Binding SelectedByokEndpoint.ApiKey, Mode=TwoWay}"
                             PasswordChar="•" RevealPassword="False" />
                    <Border Background="{DynamicResource Brush.WarningSubtle}" CornerRadius="4" Padding="8,4">
                      <TextBlock Text="{loc:Str Settings_Byok_ApiKeyInsecureWarning}"
                                 Foreground="{DynamicResource Brush.Warning}"
                                 FontSize="{DynamicResource Font.SizeCaption}"
                                 TextWrapping="Wrap" />
                    </Border>
                  </StackPanel>

                  <StackPanel Spacing="4" IsVisible="{Binding UsesCredentialStoreApiKey}">
                    <TextBlock Text="{loc:Str Settings_Byok_CredentialStoreKey}" FontSize="{DynamicResource Font.SizeCaption}"
                               Foreground="{DynamicResource Brush.TextSecondary}" />
                    <TextBox Text="{Binding ByokCredentialStoreKeyEntry, Mode=TwoWay}"
                             PasswordChar="•" RevealPassword="False"
                             PlaceholderText="{loc:Str Settings_Byok_CredentialStoreKeyPlaceholder}" />
                    <TextBlock Text="{loc:Str Settings_Byok_CredentialStoreKeyHint}"
                               FontSize="{DynamicResource Font.SizeCaption}"
                               Foreground="{DynamicResource Brush.TextTertiary}"
                               TextWrapping="Wrap" />
                    <TextBlock IsVisible="{Binding HasByokCredentialStoreEntry}"
                               Text="{loc:Str Settings_Byok_CredentialStoreKeyPresent}"
                               FontSize="{DynamicResource Font.SizeCaption}"
                               Foreground="{DynamicResource Brush.Success}" />
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2,0,0">
                      <Button Content="{loc:Str Settings_Byok_CredentialStoreKeySave}"
                              Command="{Binding SaveByokCredentialStoreKeyCommand}" />
                      <Button Content="{loc:Str Settings_Byok_CredentialStoreKeyClear}"
                              Command="{Binding ClearByokCredentialStoreKeyCommand}"
                              IsVisible="{Binding HasByokCredentialStoreEntry}" />
                    </StackPanel>
                  </StackPanel>

                  <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2,0,0">
                    <ToggleSwitch IsChecked="{Binding SelectedByokEndpoint.IsEnabled, Mode=TwoWay}" />
                    <TextBlock Text="{loc:Str Settings_Byok_IsEnabled}" VerticalAlignment="Center" />
                  </StackPanel>

                  <Button Content="{loc:Str Settings_Byok_TestEndpoint}" Padding="10,4" MinHeight="0"
                          Classes="subtle motion-action" HorizontalAlignment="Left"
                          Command="{Binding TestByokEndpointCommand}" />
                  <TextBlock Text="{Binding ByokValidationMessage}"
                             IsVisible="{Binding IsByokValidationVisible}"
                             FontSize="{DynamicResource Font.SizeCaption}"
                             Foreground="{DynamicResource Brush.TextSecondary}"
                             TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </StackPanel>

            <!-- ── Models ── -->
            <StackPanel Spacing="8">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{loc:Str SettingsGroup_ByokModels}" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button Padding="8,3" MinHeight="0"
                        Classes="subtle motion-action"
                        Command="{Binding AddByokModelCommand}">
                      <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="＋" /><TextBlock Text="{loc:Str Settings_Byok_AddModel}" />
                      </StackPanel>
                    </Button>
              </StackPanel>

              <ListBox ItemsSource="{Binding ByokModels}"
                       SelectedItem="{Binding SelectedByokModel, Mode=TwoWay}"
                       MinHeight="60" MaxHeight="180"
                       Background="{DynamicResource Brush.Surface2}"
                       BorderBrush="{DynamicResource Brush.Border1}"
                       BorderThickness="1" CornerRadius="6">
                <ListBox.ItemTemplate>
                  <DataTemplate DataType="m:ByokModel">
                    <StackPanel Spacing="2">
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                      </StackPanel>
                      <TextBlock Text="{Binding ModelId}" FontSize="{DynamicResource Font.SizeCaption}"
                                 Foreground="{DynamicResource Brush.TextTertiary}" />
                    </StackPanel>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
              <TextBlock Text="{loc:Str Settings_Byok_EmptyModels}"
                         IsVisible="{Binding !ByokModels.Count}"
                         Foreground="{DynamicResource Brush.TextTertiary}"
                         FontSize="{DynamicResource Font.SizeCaption}" />

              <!-- Model editor -->
              <Border IsVisible="{Binding SelectedByokModel, Converter={x:Static ObjectConverters.IsNotNull}}"
                      Padding="14" CornerRadius="8" Margin="0,4,0,0"
                      Background="{DynamicResource Brush.Surface2}"
                      BorderBrush="{DynamicResource Brush.Border1}"
                      BorderThickness="1">
                <StackPanel Spacing="10">
                  <DockPanel LastChildFill="False">
                    <Button DockPanel.Dock="Left" Padding="8,3" MinHeight="0"
                            Classes="subtle motion-action"
                            Command="{Binding CloseByokModelCommand}"
                            ToolTip.Tip="{loc:Str Settings_Byok_CloseModel}">
                      <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="✕" /><TextBlock Text="{loc:Str Settings_Byok_CloseModel}" />
                      </StackPanel>
                    </Button>
                    <StackPanel Orientation="Horizontal" Spacing="8" DockPanel.Dock="Right">
                      <Button Content="{loc:Str Settings_Byok_DuplicateModel}" Padding="8,3" MinHeight="0"
                              Classes="subtle motion-action"
                              Command="{Binding DuplicateByokModelCommand}" />
                      <Button Content="{loc:Str Settings_Byok_DeleteModel}" Padding="8,3" MinHeight="0"
                              Classes="danger subtle motion-action"
                              Command="{Binding DeleteByokModelCommand}" />
                    </StackPanel>
                  </DockPanel>

                  <StackPanel Spacing="4">
                    <TextBlock Text="{loc:Str Settings_Byok_ModelName}" FontSize="{DynamicResource Font.SizeCaption}"
                               Foreground="{DynamicResource Brush.TextSecondary}" />
                    <TextBox Text="{Binding SelectedByokModel.DisplayName, Mode=TwoWay}"
                             PlaceholderText="{loc:Str Settings_Byok_ModelNamePlaceholder}" />
                  </StackPanel>

                  <StackPanel Spacing="4">
                    <TextBlock Text="{loc:Str Settings_Byok_ModelId}" FontSize="{DynamicResource Font.SizeCaption}"
                               Foreground="{DynamicResource Brush.TextSecondary}" />
                    <TextBox Text="{Binding SelectedByokModel.ModelId, Mode=TwoWay}"
                             PlaceholderText="gpt-4o" />
                  </StackPanel>

                  <StackPanel Spacing="4">
                    <TextBlock Text="{loc:Str Settings_Byok_Endpoint}" FontSize="{DynamicResource Font.SizeCaption}"
                               Foreground="{DynamicResource Brush.TextSecondary}" />
                    <ComboBox ItemsSource="{Binding ByokEndpoints}"
                              SelectedValueBinding="{Binding Id}"
                              SelectedItem="{Binding SelectedByokModel.EndpointId, Converter={StaticResource ByokEndpointByIdConverter}, Mode=TwoWay}"
                              DisplayMemberBinding="{Binding Name}"
                              HorizontalAlignment="Stretch" />
                  </StackPanel>

                  <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2,0,0">
                    <ToggleSwitch IsChecked="{Binding SelectedByokModel.IsEnabled, Mode=TwoWay}" />
                    <TextBlock Text="{loc:Str Settings_Byok_IsEnabled}" VerticalAlignment="Center" />
                  </StackPanel>

                  <!-- Advanced inference / rate-limit settings. All optional — empty (null) means
                       "inherit the provider/SDK default" so existing users see no behavior change. -->
                  <Border Background="{DynamicResource Brush.Surface1}"
                          BorderBrush="{DynamicResource Brush.Border1}"
                          BorderThickness="1" CornerRadius="6" Padding="10">
                    <StackPanel Spacing="8">
                      <TextBlock Text="{loc:Str Settings_Byok_Advanced}" FontWeight="SemiBold"
                                 Foreground="{DynamicResource Brush.TextSecondary}" />

                      <StackPanel Spacing="4">
                        <TextBlock Text="{loc:Str Settings_Byok_Context}" FontSize="{DynamicResource Font.SizeCaption}"
                                   Foreground="{DynamicResource Brush.TextSecondary}" />
                        <TextBox Text="{Binding SelectedByokModel.MaxPromptTokens, Mode=TwoWay, Converter={StaticResource StringToNullableIntConverter}, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="128000" />
                        <TextBlock Text="{loc:Str Settings_Byok_ContextHint}"
                                   FontSize="{DynamicResource Font.SizeCaption}"
                                   Foreground="{DynamicResource Brush.TextTertiary}"
                                   TextWrapping="Wrap" />
                      </StackPanel>

                      <StackPanel Spacing="4">
                        <TextBlock Text="{loc:Str Settings_Byok_MaxOutputTokens}" FontSize="{DynamicResource Font.SizeCaption}"
                                   Foreground="{DynamicResource Brush.TextSecondary}" />
                        <TextBox Text="{Binding SelectedByokModel.MaxOutputTokens, Mode=TwoWay, Converter={StaticResource StringToNullableIntConverter}, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="4096" />
                        <TextBlock Text="{loc:Str Settings_Byok_MaxOutputTokensHint}"
                                   FontSize="{DynamicResource Font.SizeCaption}"
                                   Foreground="{DynamicResource Brush.TextTertiary}"
                                   TextWrapping="Wrap" />
                      </StackPanel>

                      <StackPanel Spacing="4">
                        <TextBlock Text="{loc:Str Settings_Byok_Rpm}" FontSize="{DynamicResource Font.SizeCaption}"
                                   Foreground="{DynamicResource Brush.TextSecondary}" />
                        <TextBox Text="{Binding SelectedByokModel.MaxRequestsPerMinute, Mode=TwoWay, Converter={StaticResource StringToNullableIntConverter}, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="0" />
                        <TextBlock Text="{loc:Str Settings_Byok_RpmHint}"
                                   FontSize="{DynamicResource Font.SizeCaption}"
                                   Foreground="{DynamicResource Brush.TextTertiary}"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                    </StackPanel>
                  </Border>
                </StackPanel>
              </Border>
            </StackPanel>
          </StackPanel>
        </sc:StrataSettingGroup>

        <sc:StrataSettingGroup Header="{loc:Str SettingsGroup_McpServers}">
          <sc:StrataSetting Header="{loc:Str Setting_UseMcpProxy}" Description="{loc:Str SettingDesc_UseMcpProxy}"
                            IsModified="{Binding IsUseMcpProxyModified}">
            <ToggleSwitch IsChecked="{Binding UseMcpProxy}" />
          </sc:StrataSetting>
        </sc:StrataSettingGroup>
      </StackPanel>

    <!-- ═══ Page 5: Privacy & Data ═══ -->
      <StackPanel x:Name="PagePrivacy" Classes="motion-surface" IsVisible="False" Spacing="20" Margin="36,24,36,36" MaxWidth="560">
        <StackPanel Spacing="4">
          <TextBlock Text="{loc:Str Settings_PrivacyData}" FontSize="{DynamicResource Font.SizeTitle}" FontWeight="SemiBold" />
          <TextBlock Text="{loc:Str Settings_PrivacyDataDesc}" FontSize="{DynamicResource Font.SizeCaption}"
                     Foreground="{DynamicResource Brush.TextTertiary}" />
        </StackPanel>

        <sc:StrataSettingGroup Header="{loc:Str SettingsGroup_Memory}">
          <sc:StrataSetting Header="{loc:Str Setting_AutoSaveMemories}" Description="{loc:Str SettingDesc_AutoSaveMemories}"
                            IsModified="{Binding IsEnableMemoryAutoSaveModified}">
            <ToggleSwitch IsChecked="{Binding EnableMemoryAutoSave}" />
          </sc:StrataSetting>
          <sc:StrataSetting Header="{loc:Str Setting_AutoMaintainMemories}" Description="{loc:Str SettingDesc_AutoMaintainMemories}"
                            IsModified="{Binding IsEnableMemoryAutoMaintenanceModified}">
            <ToggleSwitch IsChecked="{Binding EnableMemoryAutoMaintenance}" />
          </sc:StrataSetting>
          <sc:StrataSetting Header="{loc:Str Setting_CleanUpMemories}" Description="{Binding MemoryCleanupStatus}">
            <Button Classes="subtle motion-action" Content="{loc:Str Button_CleanUpMemories}" Padding="14,6" MinHeight="0"
                    Command="{Binding CleanUpMemoriesNowCommand}"
                    IsEnabled="{Binding !IsMemoryCleanupRunning}" />
          </sc:StrataSetting>
        </sc:StrataSettingGroup>

        <sc:StrataSettingGroup Header="{loc:Str SettingsGroup_ChatHistory}">
          <sc:StrataSetting Header="{loc:Str Setting_AutoSaveChats}" Description="{loc:Str SettingDesc_AutoSaveChats}"
                            IsModified="{Binding IsAutoSaveChatsModified}">
            <ToggleSwitch IsChecked="{Binding AutoSaveChats}" />
          </sc:StrataSetting>
        </sc:StrataSettingGroup>

        <sc:StrataSettingGroup Header="Browser">
          <sc:StrataSetting Header="Import browser cookies"
                            Description="{Binding BrowserCookieStatus}">
            <Button Classes="subtle motion-action" Content="Import cookies" Padding="14,6" MinHeight="0"
                    Command="{Binding ImportBrowserCookiesAgainCommand}" />
          </sc:StrataSetting>
          <sc:StrataSetting Header="Reset embedded browser cookies"
                            Description="Clear all Lumi browser cookies and start fresh.">
            <Button Classes="subtle motion-action" Content="Reset cookies" Padding="14,6" MinHeight="0"
                    Foreground="{DynamicResource Brush.DangerDefault}"
                    Command="{Binding ResetBrowserCookiesCommand}" />
          </sc:StrataSetting>
        </sc:StrataSettingGroup>

        <sc:StrataSettingGroup Header="{loc:Str SettingsGroup_DataManagement}">
          <sc:StrataSetting Header="{loc:Str Setting_ClearAllChats}" Description="{loc:Str SettingDesc_ClearAllChats}">
            <Button Classes="subtle motion-action" Content="{loc:Str Button_ClearChats}" Padding="14,6" MinHeight="0"
                    Foreground="{DynamicResource Brush.DangerDefault}"
                    Command="{Binding ClearAllChatsCommand}" />
          </sc:StrataSetting>
          <sc:StrataSetting Header="{loc:Str Setting_ClearAllMemories}" Description="{loc:Str SettingDesc_ClearAllMemories}">
            <Button Classes="subtle motion-action" Content="{loc:Str Button_ClearMemories}" Padding="14,6" MinHeight="0"
                    Foreground="{DynamicResource Brush.DangerDefault}"
                    Command="{Binding ClearAllMemoriesCommand}" />
          </sc:StrataSetting>
          <sc:StrataSetting Header="{loc:Str Setting_ResetAllSettings}" Description="{loc:Str SettingDesc_ResetAllSettings}">
            <Button Classes="subtle motion-action" Content="{loc:Str Button_ResetDefaults}" Padding="14,6" MinHeight="0"
                    Command="{Binding ResetSettingsCommand}" />
          </sc:StrataSetting>
        </sc:StrataSettingGroup>
      </StackPanel>

    <!-- ═══ Page 6: About ═══ -->
      <StackPanel x:Name="PageAbout" Classes="motion-surface" IsVisible="False" Spacing="20" Margin="36,24,36,36" MaxWidth="560">
        <StackPanel Spacing="4">
          <TextBlock Text="{loc:Str Settings_About}" FontSize="{DynamicResource Font.SizeTitle}" FontWeight="SemiBold" />
          <TextBlock Text="{loc:Str Settings_AboutDesc}" FontSize="{DynamicResource Font.SizeCaption}"
                     Foreground="{DynamicResource Brush.TextTertiary}" />
        </StackPanel>

        <Border Background="{DynamicResource Brush.AccentSubtle}"
                BorderBrush="{DynamicResource Brush.BorderSubtle}"
                BorderThickness="1"
                CornerRadius="{DynamicResource Radius.Overlay}"
                Padding="18">
          <StackPanel Spacing="14">
            <Border HorizontalAlignment="Left"
                    Background="{DynamicResource Brush.SurfaceCard}"
                    BorderBrush="{DynamicResource Brush.BorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="999"
                    Padding="8,2">
              <TextBlock Text="{Binding UpdateStatusBadgeText}"
                         FontSize="10"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource Brush.AccentDefault}" />
            </Border>

            <StackPanel Spacing="4">
              <TextBlock Text="{Binding UpdateHeroTitle}"
                         FontSize="{DynamicResource Font.SizeBody}"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource Brush.TextPrimary}" />
              <TextBlock Text="{Binding UpdateHeroDescription}"
                         TextWrapping="Wrap"
                         FontSize="{DynamicResource Font.SizeCaption}"
                         Foreground="{DynamicResource Brush.TextSecondary}" />
            </StackPanel>

            <Grid ColumnDefinitions="*,*"
                  RowDefinitions="Auto,Auto"
                  ColumnSpacing="16"
                  RowSpacing="10">
              <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                <TextBlock Text="{loc:Str Update_CurrentVersion}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.TextTertiary}" />
                <TextBlock Text="{Binding AppVersion, StringFormat='v{0}'}"
                           FontSize="{DynamicResource Font.SizeBody}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.TextPrimary}" />
              </StackPanel>

              <StackPanel Grid.Row="0" Grid.Column="1"
                          Spacing="2"
                          IsVisible="{Binding HasAvailableUpdateVersion}">
                <TextBlock Text="{loc:Str Update_AvailableVersion}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.TextTertiary}" />
                <TextBlock Text="{Binding AvailableUpdateVersion, StringFormat='v{0}'}"
                           FontSize="{DynamicResource Font.SizeBody}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.TextPrimary}" />
              </StackPanel>

              <StackPanel Grid.Row="1" Grid.Column="0"
                          Spacing="2"
                          IsVisible="{Binding UpdateLastCheckedText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock Text="{loc:Str Update_LastChecked}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.TextTertiary}" />
                <TextBlock Text="{Binding UpdateLastCheckedText}"
                           FontSize="{DynamicResource Font.SizeCaption}"
                           Foreground="{DynamicResource Brush.TextPrimary}" />
              </StackPanel>

              <StackPanel Grid.Row="1" Grid.Column="1"
                          Spacing="2"
                          IsVisible="{Binding UpdatePublishedText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock Text="{loc:Str Update_Published}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.TextTertiary}" />
                <TextBlock Text="{Binding UpdatePublishedText}"
                           FontSize="{DynamicResource Font.SizeCaption}"
                           Foreground="{DynamicResource Brush.TextPrimary}" />
              </StackPanel>
            </Grid>

            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="{loc:Str Update_CheckNow}"
                      Classes="subtle"
                      Padding="14,6"
                      MinHeight="0"
                      Command="{Binding CheckForUpdateCommand}"
                      IsVisible="{Binding IsCheckButtonVisible}"
                      IsEnabled="{Binding !IsCheckingForUpdate}" />
              <Button Content="{loc:Str Update_Download}"
                      Classes="accent"
                      Padding="14,6"
                      MinHeight="0"
                      Command="{Binding DownloadUpdateCommand}"
                      IsVisible="{Binding IsUpdateAvailable}" />
              <Button Content="{loc:Str Update_Restart}"
                      Classes="accent"
                      Padding="14,6"
                      MinHeight="0"
                      Command="{Binding ApplyUpdateAndRestartCommand}"
                      IsVisible="{Binding IsUpdateReadyToRestart}" />
              <Button Content="{Binding OpenReleasePageButtonText}"
                      Classes="subtle"
                      Padding="14,6"
                      MinHeight="0"
                      Command="{Binding OpenReleasePageCommand}" />
            </StackPanel>

            <ProgressBar IsIndeterminate="True"
                         IsVisible="{Binding IsCheckingForUpdate}" />

            <ProgressBar Minimum="0"
                         Maximum="100"
                         Value="{Binding UpdateDownloadProgress}"
                         IsVisible="{Binding IsUpdateDownloading}" />

            <TextBlock Text="{Binding UpdateStatusText}"
                       IsVisible="{Binding UpdateStatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       TextWrapping="Wrap"
                       FontSize="{DynamicResource Font.SizeCaption}"
                       Foreground="{DynamicResource Brush.TextSecondary}" />
          </StackPanel>
        </Border>

        <Border IsVisible="{Binding IsUpdateReleaseNotesVisible}"
                Background="{DynamicResource Brush.SurfaceSubtle}"
                BorderBrush="{DynamicResource Brush.BorderSubtle}"
                BorderThickness="1"
                CornerRadius="{DynamicResource Radius.Overlay}"
                Padding="18">
          <StackPanel Spacing="12">
            <DockPanel LastChildFill="False">
              <Button DockPanel.Dock="Right"
                      Classes="subtle motion-action"
                      Content="{Binding OpenReleasePageButtonText}"
                      Padding="12,6"
                      MinHeight="0"
                      Command="{Binding OpenReleasePageCommand}" />
              <StackPanel Spacing="2">
                <TextBlock Text="{Binding UpdateReleaseNotesHeading}"
                           FontSize="{DynamicResource Font.SizeBody}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.TextPrimary}" />
                <TextBlock Text="{Binding UpdateReleaseTitle}"
                           IsVisible="{Binding UpdateReleaseTitle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                           FontSize="{DynamicResource Font.SizeCaption}"
                           Foreground="{DynamicResource Brush.TextTertiary}" />
              </StackPanel>
            </DockPanel>

            <sc:StrataMarkdown Markdown="{Binding UpdateReleaseNotesDisplayMarkdown}" />
          </StackPanel>
        </Border>

        <sc:StrataSettingGroup Header="{loc:Str SettingsGroup_App}">
          <sc:StrataSetting Header="{loc:Str Setting_DotNetRuntime}">
            <TextBlock Text="{Binding DotNetVersion}" FontSize="{DynamicResource Font.SizeCaption}"
                       Foreground="{DynamicResource Brush.TextTertiary}" TextTrimming="CharacterEllipsis" />
          </sc:StrataSetting>
          <sc:StrataSetting Header="{loc:Str Setting_OperatingSystem}">
            <TextBlock Text="{Binding OsVersion}" FontSize="{DynamicResource Font.SizeCaption}"
                       Foreground="{DynamicResource Brush.TextTertiary}" TextTrimming="CharacterEllipsis" />
          </sc:StrataSetting>
          <sc:StrataSetting x:Name="DebugTransparencySetting"
                            Header="Window Transparency (Debug)"
                            IsVisible="False">
            <TextBlock x:Name="DebugTransparencyValue"
                       FontSize="{DynamicResource Font.SizeCaption}"
                       Foreground="{DynamicResource Brush.TextTertiary}"
                       Text="Unavailable" />
          </sc:StrataSetting>
          <sc:StrataSetting x:Name="DebugFpsOverlaySetting"
                            Header="FPS Overlay (Debug)"
                            Description="Show Avalonia's debug FPS counter overlay."
                            IsVisible="False">
            <ToggleSwitch x:Name="DebugFpsOverlayToggle" />
          </sc:StrataSetting>
        </sc:StrataSettingGroup>

        <sc:StrataSettingGroup Header="{loc:Str SettingsGroup_Statistics}">
          <sc:StrataSetting Header="{loc:Str Setting_TotalChats}">
            <TextBlock Text="{Binding TotalChats}" FontSize="{DynamicResource Font.SizeCaption}"
                       Foreground="{DynamicResource Brush.TextTertiary}" />
          </sc:StrataSetting>
          <sc:StrataSetting Header="{loc:Str Setting_TotalMemories}">
            <TextBlock Text="{Binding TotalMemories}" FontSize="{DynamicResource Font.SizeCaption}"
                       Foreground="{DynamicResource Brush.TextTertiary}" />
          </sc:StrataSetting>
          <sc:StrataSetting Header="{loc:Str Setting_StatsSkills}">
            <TextBlock Text="{Binding TotalSkills}" FontSize="{DynamicResource Font.SizeCaption}"
                       Foreground="{DynamicResource Brush.TextTertiary}" />
          </sc:StrataSetting>
          <sc:StrataSetting Header="{loc:Str Setting_StatsAgents}">
            <TextBlock Text="{Binding TotalAgents}" FontSize="{DynamicResource Font.SizeCaption}"
                       Foreground="{DynamicResource Brush.TextTertiary}" />
          </sc:StrataSetting>
          <sc:StrataSetting Header="{loc:Str Setting_StatsProjects}">
            <TextBlock Text="{Binding TotalProjects}" FontSize="{DynamicResource Font.SizeCaption}"
                       Foreground="{DynamicResource Brush.TextTertiary}" />
          </sc:StrataSetting>
        </sc:StrataSettingGroup>

        <sc:StrataSettingGroup Header="{loc:Str SettingsGroup_Credits}">
          <sc:StrataSetting Header="{loc:Str Setting_BuiltWith}"
                            Description="{loc:Str SettingDesc_BuiltWith}">
            <TextBlock Text="❤️" FontSize="16" />
          </sc:StrataSetting>
        </sc:StrataSettingGroup>
      </StackPanel>

    </StackPanel>
    </ScrollViewer>

    <!-- No results indicator -->
    <StackPanel x:Name="NoResultsPanel" Classes="motion-surface" IsVisible="False"
                VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
      <PathIcon Width="40" Height="40" Foreground="{DynamicResource Brush.TextTertiary}"
                HorizontalAlignment="Center">
        <PathIcon.Data>
          <StreamGeometry>M10 3a7 7 0 1 0 4.2 12.6l4.1 4.1a1 1 0 0 0 1.4-1.4l-4.1-4.1A7 7 0 0 0 10 3zm-5 7a5 5 0 1 1 10 0 5 5 0 0 1-10 0z</StreamGeometry>
        </PathIcon.Data>
      </PathIcon>
      <StackPanel Spacing="4" HorizontalAlignment="Center">
        <TextBlock x:Name="NoResultsQueryText" FontSize="{DynamicResource Font.SizeBody}"
                   Foreground="{DynamicResource Brush.TextSecondary}" HorizontalAlignment="Center" />
        <TextBlock Text="{loc:Str Settings_TryDifferentSearch}" FontSize="{DynamicResource Font.SizeCaption}"
                   Foreground="{DynamicResource Brush.TextTertiary}" HorizontalAlignment="Center" />
      </StackPanel>
      <Button x:Name="NoResultsClearButton" Classes="subtle motion-action" Content="{loc:Str Settings_ClearSearch}"
              Padding="12,6" MinHeight="0" HorizontalAlignment="Center"
              Foreground="{DynamicResource Brush.AccentDefault}" />
    </StackPanel>

    <!-- ═══ Cookie Import Dialog ═══ -->
    <sc:StrataDialog x:Name="CookieImportDialog"
                     Title="Import browser cookies"
                     MaxDialogWidth="460">
      <sc:StrataDialog.DialogContent>
        <StackPanel Spacing="16">

          <!-- Icon -->
          <Border Width="48" Height="48" CornerRadius="24"
                  Background="{DynamicResource Brush.AccentSubtle}"
                  HorizontalAlignment="Center">
            <PathIcon Width="24" Height="24" Foreground="{DynamicResource Brush.AccentDefault}">
              <PathIcon.Data>
                <StreamGeometry>M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z</StreamGeometry>
              </PathIcon.Data>
            </PathIcon>
          </Border>

          <!-- Description -->
          <TextBlock TextWrapping="Wrap" TextAlignment="Center" Classes="caption"
                     Foreground="{DynamicResource Brush.TextSecondary}"
                     Text="Sign into websites without logging in again. Lumi can import your cookies from an installed browser so you're already authenticated." />

          <!-- Browser/profile picker (populated in code-behind) -->
          <StackPanel x:Name="CookieProfilePicker" Spacing="4" />

          <!-- Info box -->
          <Border Background="{DynamicResource Brush.SurfaceSubtle}"
                  CornerRadius="{DynamicResource Radius.Base}"
                  Padding="12" BorderThickness="1"
                  BorderBrush="{DynamicResource Brush.BorderSubtle}">
            <StackPanel Spacing="4">
              <TextBlock Classes="caption" TextWrapping="Wrap"
                         Foreground="{DynamicResource Brush.TextTertiary}"
                         Text="• The selected browser will be briefly closed" />
              <TextBlock Classes="caption" TextWrapping="Wrap"
                         Foreground="{DynamicResource Brush.TextTertiary}"
                         Text="• Windows may ask for your password to authorize" />
              <TextBlock Classes="caption" TextWrapping="Wrap"
                         Foreground="{DynamicResource Brush.TextTertiary}"
                         Text="• Your cookies will be copied into Lumi's browser" />
              <TextBlock Classes="caption" TextWrapping="Wrap"
                         Foreground="{DynamicResource Brush.TextTertiary}"
                         Text="• Your original browser data is never modified" />
            </StackPanel>
          </Border>

          <!-- Progress (hidden until import starts) -->
          <StackPanel x:Name="CookieImportProgress" IsVisible="False" Spacing="8">
            <ProgressBar IsIndeterminate="True" />
            <TextBlock x:Name="CookieImportStatusText" Classes="caption"
                       Foreground="{DynamicResource Brush.TextSecondary}"
                       HorizontalAlignment="Center" Text="Preparing…" />
          </StackPanel>

          <!-- Actions -->
          <StackPanel x:Name="CookieImportActions" Spacing="8">
            <Button x:Name="CookieImportButton" Classes="accent motion-action"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Content="Import cookies" />
            <Button x:Name="CookieImportCancelButton" Classes="subtle motion-action"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Content="Cancel" />
          </StackPanel>

        </StackPanel>
      </sc:StrataDialog.DialogContent>
    </sc:StrataDialog>

  </Panel>
</UserControl>
